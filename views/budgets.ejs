<div class="page-title-section">
    <div class="welcome-section">
        <h2>Budgets</h2>
        <p>Set limits and stay on track with your spending goals.</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-primary" onclick="openModal('budget-modal')">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><path d="M12 2v20"/><path d="m17 5-5-3-5 3v14l5 3 5-3V5Z"/><path d="M12 22v-6.5"/></svg>
            Set Budget
        </button>
    </div>
</div>

<div class="stats-grid">
    <% if (budgets.length > 0) { %>
        <% budgets.forEach(budget => { %>
            <% 
                const pct = Math.min((budget.spent / budget.monthly_limit) * 100, 100);
                const colorClass = pct >= 100 ? 'danger' : (pct >= 80 ? 'warning' : 'success');
            %>
            <div class="card budget-card">
                <div class="card-header">
                    <h3><%= budget.category %></h3>
                    <form action="/budgets/delete/<%= budget._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure?')">
                        <button type="submit" class="btn-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                        </button>
                    </form>
                </div>
                <div class="budget-progress-info">
                    <span class="spent">₹<%= budget.spent.toLocaleString() %></span>
                    <span class="limit">of ₹<%= budget.monthly_limit.toLocaleString() %></span>
                </div>
                <div class="progress-bar-container">
                    <div class="progress-bar <%= colorClass %>" style="width: <%= pct %>%"></div>
                </div>
                <div class="budget-footer">
                    <span><%= 100 - Math.round(pct) %>% remaining</span>
                    <span class="status-tag <%= colorClass %>"><%= pct >= 100 ? 'Exceeded' : (pct >= 80 ? 'Warning' : 'On Track') %></span>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="card" style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--text-muted);">No budgets set for this month.</div>
    <% } %>
</div>

<!-- Add Budget Modal -->
<div id="budget-modal" class="modal-overlay">
    <div class="modal">
        <div class="modal-header">
            <h3>Set Monthly Budget</h3>
            <button class="modal-close" onclick="closeModal('budget-modal')">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
        </div>
        <form action="/budgets/add" method="POST" class="auth-form">
            <div class="form-group">
                <label>Category</label>
                <select name="category" class="search-bar-input" style="padding: 0.75rem 1rem; background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; color: var(--text-color); font-family: inherit;" required>
                    <% Categories.forEach(cat => { %>
                        <option value="<%= cat %>"><%= cat %></option>
                    <% }); %>
                </select>
            </div>
            <div class="form-group">
                <label>Monthly Limit (₹)</label>
                <input type="number" name="monthly_limit" placeholder="0.00" required>
            </div>
            <button type="submit" class="btn btn-primary w-full">Set Budget</button>
        </form>
    </div>
</div>
