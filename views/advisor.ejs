<div class="page-title-section">
    <div class="welcome-section">
        <h2>AI Wealth Advisor</h2>
        <p>Advanced insights and predictive analysis for your financial future.</p>
    </div>
</div>

<div class="advisor-container">
    <div class="advisor-hero card animated-gradient">
        <div class="advisor-icon-large pulse">
             <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12.001l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 11.999l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
        </div>
        <div class="hero-content">
            <h3>Intelligence Report Ready</h3>
            <p>I've analyzed your patterns across <%= new Date().toLocaleString('default', { month: 'long' }) %> and forecasted your month-end results.</p>
        </div>
    </div>

    <!-- Summary Section -->
    <div class="stats-grid" style="margin-bottom: 2rem;">
        <div class="card stat-card">
            <div class="stat-info">
                <span class="stat-label">Spent This Month</span>
                <h3 class="stat-value">₹<%= summary.total.toLocaleString() %></h3>
                <span class="stat-change <%= summary.budgetUsagePct > 100 ? 'negative' : 'positive' %>">
                    <%= summary.budgetUsagePct %>% of overall budget used
                </span>
            </div>
        </div>
        <div class="card stat-card">
            <div class="stat-info">
                <span class="stat-label">Top Category</span>
                <h3 class="stat-value"><%= summary.highestCategory %></h3>
                <span class="stat-change">Primary source of expense</span>
            </div>
        </div>
        <div class="card stat-card">
            <div class="stat-info">
                <span class="stat-label">Projected Total</span>
                <h3 class="stat-value">₹<%= prediction.estimated.toLocaleString() %></h3>
                <span class="stat-change info">Based on daily pace</span>
            </div>
        </div>
    </div>

    <!-- Category Intelligence Table -->
    <% if (table.length > 0) { %>
    <div class="card" style="margin-bottom: 2rem;">
        <div class="card-header">
            <h3>Budget Intelligence Table</h3>
        </div>
        <div class="transaction-table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Total Spent</th>
                        <th>Budget</th>
                        <th>% Used</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% table.forEach(row => { %>
                        <tr>
                            <td style="font-weight: 600;"><%= row.category %></td>
                            <td>₹<%= row.spent.toLocaleString() %></td>
                            <td style="color: var(--text-muted);">₹<%= row.budget.toLocaleString() %></td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <div style="flex-grow: 1; height: 4px; background: var(--border-color); border-radius: 2px;">
                                        <div style="width: <%= Math.min(row.pctUsed, 100) %>%; height: 100%; background: <%= row.pctUsed > 100 ? '#ef4444' : (row.pctUsed > 80 ? '#f59e0b' : '#3b82f6') %>; border-radius: 2px;"></div>
                                    </div>
                                    <span><%= row.pctUsed %>%</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge-category" style="background: <%= row.status === 'Exceeded' ? 'rgba(239, 68, 68, 0.1)' : (row.status === 'Warning' ? 'rgba(245, 158, 11, 0.1)' : 'rgba(16, 185, 129, 0.1)') %>; color: <%= row.status === 'Exceeded' ? '#ef4444' : (row.status === 'Warning' ? '#f59e0b' : '#10b981') %>">
                                    <%= row.status %>
                                </span>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    <% } %>

    <!-- Recommended Budget Plan -->
    <% if (recommendations.length > 0) { %>
    <div class="card" style="margin-bottom: 2rem; border: 1px solid rgba(59, 130, 246, 0.3);">
        <div class="card-header" style="background: rgba(59, 130, 246, 0.05); border-bottom: 1px solid var(--border-color);">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-color);"><path d="m12 14 4-4"/><path d="m3.34 19 1.4-1.4"/><path d="D12 21a9 9 0 1 1 0-18 9 9 0 0 1 0 18Z"/><path d="m5 10 2 2 4-4"/></svg>
                <h3 style="margin: 0; color: var(--accent-color);">Automated Budget Plan</h3>
            </div>
            <span class="badge-category" style="background: var(--accent-color); color: white;">AI Optimized</span>
        </div>
        <div class="transaction-table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Spending Target</th>
                        <th>AI Rationale</th>
                        <th>Saving Potential</th>
                    </tr>
                </thead>
                <tbody>
                    <% recommendations.forEach(rec => { %>
                        <tr>
                            <td style="font-weight: 600;"><%= rec.category %></td>
                            <td style="color: var(--accent-color); font-weight: 700;">₹<%= rec.recommendedBudget.toLocaleString() %></td>
                            <td style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.4;"><%= rec.why %></td>
                            <td style="color: #10b981; font-weight: 600;">₹<%= rec.savingsPotential.toLocaleString() %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <div style="padding: 1.25rem; background: rgba(16, 185, 129, 0.05); border-top: 1px solid var(--border-color); text-align: center;">
            <span style="font-size: 0.95rem; color: #10b981; font-weight: 600;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle; margin-right: 4px;"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12V8h16v4"/><path d="m15 19-3-3-3 3"/><path d="M12 16V9"/><circle cx="12" cy="17" r="5"/></svg>
                Total Monthly Savings Potential: ₹<%= recommendations.reduce((sum, r) => sum + r.savingsPotential, 0).toLocaleString() %>
            </span>
        </div>
    </div>
    <% } %>

    <!-- Behavioral Savings Habits (Requirement for Data-Driven Advice) -->
    <% if (behavioral.length > 0) { %>
    <div class="card-header" style="margin: 2rem 0 1rem 0;">
        <h3>Behavioral Savings Habits</h3>
    </div>
    <div class="suggestions-large-grid" style="margin-bottom: 2rem;">
        <% behavioral.forEach(b => { %>
            <div class="suggestion-card card status-tip" style="border-left: 4px solid #10b981;">
                <div class="suggestion-header">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span class="suggestion-category" style="background: rgba(16, 185, 129, 0.1); color: #10b981;"><%= b.type === 'frequency' ? 'Frequency Alert' : 'Leak Detected' %></span>
                    </div>
                    <div class="suggestion-status-icon type-tip" style="color: #10b981;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M2 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="M12 22v-2"/><path d="m19.07 19.07-1.41-1.41"/><path d="M22 12h-2"/><path d="m17.66 6.34 1.41-1.41"/><path d="M15 13a3 3 0 1 0-6 0"/></svg>
                    </div>
                </div>
                <div style="margin-bottom: 0.75rem;">
                    <h4 style="margin: 0; font-size: 1rem;"><%= b.habit %></h4>
                    <span style="font-size: 0.8rem; color: var(--text-muted);"><%= b.frequency %></span>
                </div>
                <p class="suggestion-body" style="font-size: 0.9rem; color: var(--text-main); font-weight: 500;"><%= b.action %></p>
                <div style="margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border-color); color: #10b981; font-weight: 700;">
                    Est. Monthly Savings: ₹<%= b.potentialSavings.toLocaleString() %>
                </div>
            </div>
        <% }); %>
    </div>
    <% } %>

    <!-- Insight Cards -->
    <div class="card-header" style="margin: 2rem 0 1rem 0;">
        <h3>Detailed Insights & Predictions</h3>
    </div>
    <div class="suggestions-large-grid">
        <% insights.forEach(s => { %>
            <% 
                let icon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>'; // Default Info Icon
                
                if (s.type === 'warning') icon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
                if (s.type === 'trend') icon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 12-7 7-7-7"/><path d="M12 19V5"/></svg>';
                if (s.type === 'tip') icon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M2 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="M12 22v-2"/><path d="m19.07 19.07-1.41-1.41"/><path d="M22 12h-2"/><path d="m17.66 6.34 1.41-1.41"/><path d="M15 13a3 3 0 1 0-6 0"/></svg>';
            %>
            <div class="suggestion-card card status-<%= s.type || 'info' %>">
                <div class="suggestion-header">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span class="suggestion-category"><%= s.category %></span>
                    </div>
                    <div class="suggestion-status-icon type-<%= s.type %>">
                        <%- icon %>
                    </div>
                </div>
                <p class="suggestion-body"><%= s.message %></p>
                <div class="suggestion-footer">
                    <button class="btn btn-outline btn-sm">Take Action</button>
                </div>
            </div>
        <% }); %>

        <!-- Forecast Card -->
        <div class="suggestion-card card status-forecast">
            <div class="suggestion-header">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <span class="suggestion-category">AI Prediction</span>
                </div>
                <div class="suggestion-status-icon type-forecast" style="background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15V6"/><path d="M18.5 18a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/><path d="M12 12H3"/><path d="M16 6H3"/><path d="M12 18H3"/></svg>
                </div>
            </div>
            <p class="suggestion-body"><%= prediction.message %></p>
        </div>
    </div>
</div>


