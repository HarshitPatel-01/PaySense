<div class="dashboard-header">
    <div class="welcome-section">
        <h2>Dashboard Overview</h2>
        <p>Welcome back, <%= user.name %>! Here's what's happening with your money.</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-primary" onclick="openTransactionModal()">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Add Transaction
        </button>
    </div>
</div>

<div class="stats-grid">
    <div class="card stat-card">
        <div class="stat-icon income">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        </div>
        <div class="stat-info">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span class="stat-label">Total Balance</span>
                <button class="btn-icon" onclick="openModal('balance-modal')" style="padding: 0.2rem;" title="Edit Balance">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
            </div>
            <h3 class="stat-value">₹<%= stats.totalBalance.toLocaleString() %></h3>
            <span class="stat-change positive">+2.5% from last month</span>
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-icon expense">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Monthly Spending</span>
            <h3 class="stat-value">₹<%= stats.monthlyExpense.toLocaleString() %></h3>
            <span class="stat-change negative">+12% from last month</span>
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-icon budget">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m17 5-5-3-5 3v14l5 3 5-3V5Z"/><path d="M12 22v-6.5"/></svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Active Budgets</span>
            <h3 class="stat-value"><%= stats.activeBudgets %> Categories</h3>
            <span class="stat-change">4 on track, 1 warning</span>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="card chart-container">
        <div class="chart-header">
            <h3>Spending Overview</h3>
            <select class="chart-filter" style="background-color: var(--card-bg); border: 1px solid var(--border-color); color: var(--text-color); padding: 0.5rem; border-radius: 8px;">
                <option>Last 7 Days</option>
                <option>Last 30 Days</option>
            </select>
        </div>
        <div style="position: relative; height: 300px; width: 100%;">
            <canvas id="spendingChart"></canvas>
        </div>
    </div>

    <div class="card recent-transactions">
        <div class="card-header">
            <h3>Recent Transactions</h3>
            <a href="/transactions" class="view-all">View All</a>
        </div>
        <div class="transaction-table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Merchant</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (transactions.length > 0) { %>
                        <% transactions.forEach(tx => { %>
                            <tr>
                                <td><%= new Date(tx.date).toLocaleDateString() %></td>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-color);"><%= tx.merchant %></div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);"><%= tx.note || '' %></div>
                                </td>
                                <td>
                                    <span class="badge-category"><%= tx.category %></span>
                                </td>
                                <td style="font-weight: 600;">₹<%= tx.amount.toLocaleString() %></td>
                                <td>
                                    <form action="/transactions/delete/<%= tx._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Delete this transaction?')">
                                        <button type="submit" class="btn-icon delete-btn">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">No transactions yet.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card advisor-peek">
    <div class="peek-header">
        <div class="peek-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-color);"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12.001l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 11.999l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            <h3>AI Advisor Insights</h3>
        </div>
        <a href="/advisor" class="view-all">Deep Dive</a>
    </div>
    <div class="insight-list">
        <% suggestions.slice(0, 2).forEach(s => { %>
            <div class="insight-item">
                <span class="insight-cat"><%= s.category %></span>
                <p class="insight-text"><%= s.message %></p>
            </div>
        <% }); %>
    </div>
</div>

<script>
    const chartData7 = {
        labels: <%- JSON.stringify(chartLabels7) %>,
        data: <%- JSON.stringify(chartData7) %>
    };
    const chartData30 = {
        labels: <%- JSON.stringify(chartLabels30) %>,
        data: <%- JSON.stringify(chartData30) %>
    };

    const ctx = document.getElementById('spendingChart').getContext('2d');
    
    // Gradient Background
    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(59, 130, 246, 0.5)');
    gradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

    const spendingChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: chartData7.labels,
            datasets: [{
                label: 'Spending',
                data: chartData7.data,
                borderColor: '#3b82f6',
                borderWidth: 3,
                backgroundColor: gradient,
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#ffffff',
                pointBorderColor: '#3b82f6',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'rgba(15, 23, 42, 0.9)',
                    titleColor: '#fff',
                    bodyColor: '#e2e8f0',
                    padding: 12,
                    borderColor: 'rgba(255,255,255,0.1)',
                    borderWidth: 1,
                    displayColors: false,
                    callbacks: {
                        label: function(context) {
                            return '₹ ' + context.parsed.y.toLocaleString();
                        }
                    }
                }
            },
            scales: {
                y: { 
                    display: true, 
                    grid: { color: 'rgba(255, 255, 255, 0.05)' },
                    ticks: { callback: function(value) { return '₹' + value; } }
                },
                x: { 
                    grid: { display: false } 
                }
            }
        }
    });

    // Handle Filter Change
    document.querySelector('.chart-filter').addEventListener('change', function(e) {
        if (e.target.value === 'Last 30 Days') {
            spendingChart.data.labels = chartData30.labels;
            spendingChart.data.datasets[0].data = chartData30.data;
        } else {
            spendingChart.data.labels = chartData7.labels;
            spendingChart.data.datasets[0].data = chartData7.data;
        }
        spendingChart.update();
    });
</script>
